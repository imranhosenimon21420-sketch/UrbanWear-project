# Copy to .env.local and fill in values (never commit .env.local)

# If Atlas returns "bad auth", reset the DB user password and paste the URI from Atlas → Connect → Drivers.
# Password characters like @ : / ? # must be percent-encoded in the URI.
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.yb3v7u1.mongodb.net/urbanwear?retryWrites=true&w=majority&appName=Cluster0

# Required for auth routes (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Comma-separated emails that receive admin role on first registration
ADMIN_EMAILS=

# One-time first admin: set a long random string, open /admin/setup, then create the first admin. Disabled once any admin exists.
ADMIN_BOOTSTRAP_SECRET=
